# Production environment for the Heisenberg quantum-stack platform.
#
# Copy to /etc/quantum-stack/jobsvc.env, set strict perms, edit:
#   sudo install -m 640 -o jobsvc -g jobsvc \
#        platform/deploy/.env.production.example /etc/quantum-stack/jobsvc.env
#
# Read by jobsvc.service, jobsvc-worker@.service, calibration.service via
# `EnvironmentFile=/etc/quantum-stack/jobsvc.env`.

# ---- Database --------------------------------------------------------------
# IMPORTANT: replace the password with the one you set when bootstrapping
# Postgres (see install/server_systemd.md §3).
JOBSVC_DATABASE_URL=postgresql+asyncpg://jobsvc:CHANGE_ME@127.0.0.1:5432/jobsvc

# ---- Auth ------------------------------------------------------------------
# IMPORTANT: generate with `openssl rand -hex 32` and paste the result.
# Anyone who knows this can mint admin JWTs for your service.
JOBSVC_JWT_SECRET=CHANGE_ME_A_LONG_RANDOM_HEX_STRING
JOBSVC_JWT_ACCESS_MINUTES=60
JOBSVC_JWT_REFRESH_DAYS=14

# ---- Logging / observability ----------------------------------------------
JOBSVC_LOG_JSON=true
JOBSVC_LOG_LEVEL=INFO

# ---- Worker tuning --------------------------------------------------------
JOBSVC_WORKER_LEASE_SECONDS=300
JOBSVC_WORKER_POLL_INTERVAL_SECONDS=1.0

# ---- Where the spinor registry lives --------------------------------------
JOBSVC_SPINOR_REGISTRY_ROOT=/opt/quantum-stack/spinor/registry

# ---- Engine binding -------------------------------------------------------
# After `cmake --build build`, the nanobind extension lives here.
PYTHONPATH=/opt/quantum-stack/build/photon/bindings/python

# ---- Calibration store ----------------------------------------------------
# The `jobsvc` user's HOME must point somewhere it can write.
HOME=/var/cache

# ---- Submission mode ------------------------------------------------------
#   cassette - replays recorded JSON (default; safe; no creds needed)
#   live     - hits real providers (need creds below)
#   local    - drives the C++ LocalProvider (no network)
SPINOR_SUBMIT_MODE=cassette

# ---- Provider credentials (only needed in `live` mode) --------------------
# IBM
#IBM_QUANTUM_TOKEN=

# AWS Braket — uses standard ~/.aws/credentials of the jobsvc user
# Place the file at /var/lib/jobsvc/.aws/credentials, chmod 600, owner jobsvc.

# Azure Quantum
#AZURE_QUANTUM_RESOURCE_ID=/subscriptions/.../resourceGroups/.../providers/Microsoft.Quantum/Workspaces/...
#AZURE_QUANTUM_LOCATION=westus

# ---- CORS (only needed if the playground SPA lives on GitHub Pages) -------
# Pattern A (default): SPA served by nginx on this same host -> leave empty.
# Pattern B (SPA on GitHub Pages): set to the origin(s) that may call /api.
#JOBSVC_CORS_ORIGINS=["https://nimesh08.github.io"]
