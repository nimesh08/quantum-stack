# Dockerfile.playground — multi-stage: Vite build, then nginx static.

FROM node:22-alpine AS build
WORKDIR /app
COPY platform/playground/package.json ./package.json
COPY platform/playground/package-lock.json* ./
RUN npm install --no-audit --no-fund
COPY platform/playground/. .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY platform/deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
