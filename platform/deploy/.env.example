# Phase D — example environment.
# Copy to `.env` and edit.

# Used by FastAPI to sign JWTs. MUST be changed in production.
JWT_SECRET=change-me-in-production

# spinor_submit mode: cassette | live | local.
# - cassette: replays recorded JSON; safe in CI.
# - live:     real provider credentials required (IBM/AWS/Azure).
# - local:    drives the C++ LocalProvider via spinorc.
SPINOR_SUBMIT_MODE=cassette

# IBM live mode: set IBM_QUANTUM_TOKEN and use a `services` channel.
# IBM_QUANTUM_TOKEN=...

# AWS Braket: standard ~/.aws/credentials; no env knob needed.

# Azure Quantum: set AZURE_QUANTUM_RESOURCE_ID + AZURE_QUANTUM_LOCATION.
