# /etc/heisenberg/heisenberg.env -- shared configuration for the
# heisenberg-* systemd units. Copy this file there and edit. Owner
# should be `heisenberg:heisenberg` with mode 640.
#
# Author: Nimesh Cheedella.

# --- Required ----------------------------------------------------------------

# Where heisenberg stores SQLite (when used), the calibration cache,
# the JWT secret, and the PID file. Must be writable by the
# `heisenberg` system user.
HEISENBERG_DATA_DIR=/var/lib/heisenberg

# Database URL. Default is SQLite at $HEISENBERG_DATA_DIR/jobsvc.db;
# override with Postgres for multi-replica production.
# JOBSVC_DATABASE_URL=postgresql+asyncpg://heisenberg:CHANGEME@localhost:5432/heisenberg

# Where the chip YAMLs live. The Debian/macOS package install paths
# are pre-baked; for source builds point this at the repo's
# `spinor/registry/` directory.
SPINOR_REGISTRY_ROOT=/usr/share/heisenberg/registry

# JWT secret. `heisenberg init` generates one at
# $HEISENBERG_DATA_DIR/jwt.secret if this is unset; in production
# pin it explicitly so it survives reinstalls.
# JOBSVC_JWT_SECRET=please-change-me

# --- Submission mode ---------------------------------------------------------

# cassette | live | local. Live mode requires per-vendor credentials
# (IBM_QUANTUM_TOKEN, AWS_*, AZURE_*) injected via the same env file.
SPINOR_SUBMIT_MODE=cassette

# --- Logging -----------------------------------------------------------------

# Production: structured JSON logs to journald.
JOBSVC_LOG_JSON=true
JOBSVC_LOG_LEVEL=INFO
